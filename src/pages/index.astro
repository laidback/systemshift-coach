---
import '../styles/global.css';

const bookingLink = "mailto:hello@systemshift.coach"; // TODO: replace with Cal.com link when ready
const linkedInLink = "https://linkedin.com/in/lukasciszewski";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Systemic coaching for IT professionals ready to shift. By Lukas Ciszewski — 20+ years in IT, trained systemic coach." />
  <title>SystemShift — Coaching for IT Professionals</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- Header -->
  <header>
    <a class="logo" href="/">systemshift.coach</a>
    <div class="lang-toggle">
      <button class="active" id="btn-en" onclick="setLang('en')">EN</button>
      <button id="btn-de" onclick="setLang('de')">DE</button>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>The system isn&rsquo;t broken.<br>You&rsquo;re just running the wrong one.</h1>
      <p class="sub">Systemic coaching for IT professionals ready to shift.</p>
      <a class="btn" href={bookingLink} target="_blank" rel="noopener">Book a free discovery call &rarr;</a>
      <div class="de-notice">🇩🇪 Deutsche Version — coming soon.</div>
    </div>
  </section>

  <!-- Problem -->
  <section>
    <div class="container">
      <p>
        You&rsquo;re senior. You&rsquo;re capable. You&rsquo;ve shipped things most people only read about.
        And still &mdash; something feels off. Maybe it&rsquo;s the burnout you keep patching.
        The promotion that didn&rsquo;t feel like you thought it would.
        The team you lead but can&rsquo;t quite reach.
        The gap between who you are at work and who you want to be.
      </p>
      <p>That&rsquo;s not a productivity problem. It&rsquo;s a systems problem.</p>
      <div class="de-notice">🇩🇪 Deutsche Version — coming soon.</div>
    </div>
  </section>

  <!-- What is systemic coaching -->
  <section>
    <div class="container">
      <h2>What is systemic coaching?</h2>
      <p>
        Systemic coaching looks beyond habits and goals. It maps the whole system &mdash;
        your role, your relationships, your organization, your identity &mdash;
        and finds where it&rsquo;s stuck. Then we shift it.
      </p>
      <div class="de-notice">🇩🇪 Deutsche Version — coming soon.</div>
    </div>
  </section>

  <!-- Who it's for -->
  <section>
    <div class="container">
      <h2>Who it&rsquo;s for</h2>
      <ul class="list">
        <li>Senior engineers and tech leads feeling the ceiling</li>
        <li>Engineering managers in transition (IC &rarr; lead &rarr; director)</li>
        <li>CTOs and founders carrying too much, alone</li>
        <li>Anyone in IT whose work has become their entire identity</li>
      </ul>
      <div class="de-notice">🇩🇪 Deutsche Version — coming soon.</div>
    </div>
  </section>

  <!-- How it works / Booking -->
  <section id="booking">
    <div class="container">
      <h2>How it works</h2>
      <div class="pricing">
        <div class="pricing-item">
          <span class="label">Single session</span>
          <span class="detail">60 min &nbsp;/&nbsp; 130&euro;</span>
        </div>
        <div class="pricing-item">
          <span class="label">6-session package</span>
          <span class="detail">130&euro; / session</span>
        </div>
        <div class="pricing-item">
          <span class="label">Language</span>
          <span class="detail">German or English</span>
        </div>
        <div class="pricing-item">
          <span class="label">Format</span>
          <span class="detail">Video call</span>
        </div>
      </div>
      <a class="btn btn-ghost" href={bookingLink} target="_blank" rel="noopener">
        Book your free 30-min discovery call &rarr;
      </a>
      <div class="de-notice">🇩🇪 Deutsche Version — coming soon.</div>
    </div>
  </section>

  <!-- About -->
  <section>
    <div class="container">
      <h2>About</h2>
      <p>
        I spent 20+ years in IT &mdash; as engineer, lead, and leader.
        I know the culture, the pressure, the identity traps.
        I&rsquo;m also a trained systemic coach.
        That combination is SystemShift.
      </p>
      <div class="de-notice">🇩🇪 Deutsche Version — coming soon.</div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <span class="footer-brand">systemshift.coach</span>
    <div class="footer-links">
      <a href={bookingLink} target="_blank" rel="noopener">Book a call ↗</a>
      <a href={linkedInLink} target="_blank" rel="noopener">LinkedIn ↗</a>
    </div>
  </footer>

  <script>
    function setLang(lang: string) {
      document.body.classList.toggle('lang-de', lang === 'de');
      (document.getElementById('btn-en') as HTMLButtonElement).classList.toggle('active', lang === 'en');
      (document.getElementById('btn-de') as HTMLButtonElement).classList.toggle('active', lang === 'de');
    }
  </script>

</body>
</html>
